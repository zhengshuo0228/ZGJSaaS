generator client {
  provider = "prisma-client-js"
  output   = "../server/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Store {
  id          String       @id
  name        String
  city        String
  departments Department[]
  users       User[]
  orders      PurchaseOrder[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Department {
  id        String   @id
  name      String
  storeId   String
  isPreset  Boolean  @default(true)
  store     Store    @relation(fields: [storeId], references: [id])
  users     User[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId])
}

model Position {
  id               String         @id
  name             String
  department       String
  isPreset         Boolean        @default(true)
  rank             Int
  permissions      Json
  adminPermissions Json
  users            UserPosition[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model User {
  id            String         @id
  username      String         @unique
  passwordHash  String
  email         String?
  realName      String
  storeId       String
  departmentId  String
  status        String         @default("active")
  store         Store          @relation(fields: [storeId], references: [id])
  department    Department     @relation(fields: [departmentId], references: [id])
  positions     UserPosition[]
  registrations Registration[]
  notifications Notification[]
  orders        PurchaseOrder[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([storeId])
  @@index([departmentId])
}

model UserPosition {
  userId     String
  positionId String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  position   Position @relation(fields: [positionId], references: [id], onDelete: Cascade)

  @@id([userId, positionId])
}

model Registration {
  id           String   @id @default(cuid())
  username     String
  passwordHash String
  realName     String
  storeId      String
  departmentId String
  positionId   String
  remark       String?
  status       String   @default("pending")
  applicantId  String?
  applicant    User?    @relation(fields: [applicantId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Notification {
  id          String   @id @default(cuid())
  type        String
  title       String
  content     String
  recipientId String?
  linkType    String?
  linkId      String?
  read        Boolean  @default(false)
  recipient   User?    @relation(fields: [recipientId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([recipientId])
}

model Ingredient {
  id          String   @id
  category    String
  subCategory String
  name        String
  defaultQty  Int
  unit        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PurchaseOrder {
  id        String              @id @default(cuid())
  userId    String
  storeId   String
  status    String              @default("pending")
  user      User                @relation(fields: [userId], references: [id])
  store     Store               @relation(fields: [storeId], references: [id])
  items     PurchaseOrderItem[]
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@index([userId])
  @@index([storeId])
}

model PurchaseOrderItem {
  id        String        @id @default(cuid())
  orderId   String
  menuId    String?
  name      String
  qty       Int
  unit      String
  order     PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Authorization {
  id        String   @id @default(cuid())
  userId    String
  type      String
  targetId  String
  createdAt DateTime @default(now())
}
