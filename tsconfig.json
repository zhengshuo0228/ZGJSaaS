{
  "extends": "miaoda-expo-devkit/tsconfig-base",
  "compilerOptions": {
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "src",
    "nativewind-env.d.ts",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ],
  "exclude": [
    "babel.config.js",
    "metro.config.js",
    "tailwind.config.js"
  ]
}
