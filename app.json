{
  "expo": {
    "name": "灶管家",
    "slug": "zaoguanjia",
    "version": "1.0.170",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF7ED"
    },
    "ios": {
      "supportsTablet": true,
      "buildNumber": "2",
      "bundleIdentifier": "com.zaoguanjia.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFF7ED"
      },
      "predictiveBackGestureEnabled": false,
      "versionCode": 2,
      "package": "com.zaoguanjia.app"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-sqlite",
      "expo-font",
      "expo-system-ui",
      "@react-native-async-storage/expo-with-async-storage",
      "expo-image",
      "expo-sharing",
      "expo-file-system",
      "expo-document-picker",
      [
        "expo-camera",
        {
          "cameraPermission": "允许 $(PRODUCT_NAME) 访问相机，用于拍摄水印照片。",
          "microphonePermission": "允许 $(PRODUCT_NAME) 访问麦克风，用于录制水印视频。",
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "允许 $(PRODUCT_NAME) 访问相机，用于拍摄照片。",
          "photosPermission": "允许 $(PRODUCT_NAME) 访问相册，用于上传图片或视频。"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification/ic_notification_96.png",
          "color": "#F97316",
          "sounds": [],
          "iosDisplayInForeground": true
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "允许 $(PRODUCT_NAME) 访问相册，用于保存图片或视频。",
          "savePhotosPermission": "允许 $(PRODUCT_NAME) 保存图片或视频到相册。"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "允许 $(PRODUCT_NAME) 获取当前位置，用于生成水印地点信息。"
        }
      ],
      "expo-updates",
      "expo-video"
    ],
    "router": {
      "root": "src"
    },
    "experiments": {
      "typedRoutes": true
    },
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
